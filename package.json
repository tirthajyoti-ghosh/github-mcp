{
  "name": "github-mcp",
  "version": "0.1.0",
  "description": "A thin remote (Streamable HTTP) MCP server for GitHub, usable from Claude web, mobile, desktop, and CLI.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "github-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc -p api/tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^21.0.0",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@vercel/node": "^3.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
