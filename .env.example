# Port the HTTP server listens on
PORT=3000

# GitHub personal access token used to act on your behalf.
# Create one at https://github.com/settings/tokens (fine-grained or classic).
# Scopes for core read+write: repo, read:user.
GITHUB_TOKEN=ghp_your_token_here

# Optional shared secret that gates the /mcp endpoint.
# If set, clients must send: Authorization: Bearer <MCP_AUTH_TOKEN>
# Leave empty to disable (NOT recommended for a public URL).
MCP_AUTH_TOKEN=
